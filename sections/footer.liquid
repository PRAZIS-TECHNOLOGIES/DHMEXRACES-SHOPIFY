{% comment %}
  Footer Section for DHMEXRACES
  Includes: Info, Navigation, Social Media, Copyright
{% endcomment %}

<footer class="footer">
  <div class="footer__container">
    <!-- Top Section -->
    <div class="footer__top">
      <!-- Column 1: About -->
      <div class="footer__column footer__column--about">
        <h3 class="footer__heading">COPA SCOTT DHMEXRACES 2026</h3>
        <p class="footer__description">
          El campeonato nacional de downhill MTB más grande de México.
          $500,000 MXN en premios totales distribuidos en 5 sedes a lo largo del año.
        </p>
        <div class="footer__stats">
          <div class="footer__stat">
            <div class="footer__stat-number">5</div>
            <div class="footer__stat-label">Sedes</div>
          </div>
          <div class="footer__stat">
            <div class="footer__stat-number">13</div>
            <div class="footer__stat-label">Categorías</div>
          </div>
          <div class="footer__stat">
            <div class="footer__stat-number">$500K</div>
            <div class="footer__stat-label">Premios</div>
          </div>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="footer__column">
        <h4 class="footer__heading">Enlaces Rápidos</h4>
        <ul class="footer__links">
          <li><a href="/">Inicio</a></li>
          <li><a href="/pages/ranking">Ranking</a></li>
          <li><a href="/pages/ranking-overall">Overall</a></li>
          <li><a href="/products/inscripcion-guanajuato-2026">Inscripciones</a></li>
          <li><a href="/cart">Carrito</a></li>
        </ul>
      </div>

      <!-- Column 3: Sedes -->
      <div class="footer__column">
        <h4 class="footer__heading">Sedes 2026</h4>
        <ul class="footer__links">
          <li>SEDE 1 - Guanajuato<span class="footer__date">21-22 Feb</span></li>
          <li>SEDE 2 - Puebla<span class="footer__date">21-22 Mar</span></li>
          <li>SEDE 3 - Guadalajara<span class="footer__date">30-31 May</span></li>
          <li>SEDE 4 - Ixtapan de la Sal<span class="footer__date">18-19 Jul</span></li>
          <li>SEDE 5 - Taxco<span class="footer__date">24-25 Oct</span></li>
        </ul>
      </div>

      <!-- Column 4: Social & Contact -->
      <div class="footer__column">
        <h4 class="footer__heading">Síguenos</h4>
        <div class="footer__social">
          <a href="https://www.instagram.com/dhmex_races" target="_blank" rel="noopener noreferrer" class="footer__social-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="2"/>
              <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/>
              <circle cx="18" cy="6" r="1" fill="currentColor"/>
            </svg>
            <span>@dhmex_races</span>
          </a>
        </div>
        <div class="footer__contact">
          <h4 class="footer__heading" style="margin-top: 20px;">Contacto</h4>
          <p class="footer__contact-info">
            <a href="mailto:info@dhmexraces.com">info@dhmexraces.com</a>
          </p>
        </div>
      </div>
    </div>

    <!-- Sponsors Section -->
    <div class="footer__sponsors">
      <div class="footer__sponsors-label">Patrocinadores Oficiales:</div>
      <div class="footer__sponsors-list">
        SCOTT • SHIMANO • RED BULL • MOTUL • SRAM • SCHWALBE • FOX FACTORY • VITTORIA • LAZER • GIRO • ALPINESTARS • RACE FACE • SYNCROS • ZEFAL
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="footer__bottom">
      <div class="footer__copyright">
        <p>&copy; {{ 'now' | date: '%Y' }} DHMEXRACES. Todos los derechos reservados.</p>
      </div>
      <div class="footer__powered">
        <p class="footer__powered-text">Sitio web desarrollado por</p>
        <a href="https://prazis.com.mx" target="_blank" rel="noopener noreferrer" class="footer__powered-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="currentColor"/>
          </svg>
          <span class="footer__powered-brand">PRAZIS.COM.MX</span>
        </a>
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background: #000000;
    border-top: 2px solid rgba(255, 77, 0, 0.3);
    padding: 60px 0 30px;
    margin-top: 80px;
  }

  .footer__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Top Section */
  .footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 50px;
  }

  @media (max-width: 1024px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 640px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }

  /* Column */
  .footer__column {
    color: rgba(255, 255, 255, 0.8);
  }

  .footer__heading {
    font-size: 1.125rem;
    font-weight: 700;
    color: #FF4D00;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer__column--about .footer__heading {
    font-size: 1.5rem;
    background: linear-gradient(135deg, #FF4D00, #FFB800);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer__description {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 20px;
  }

  /* Stats */
  .footer__stats {
    display: flex;
    gap: 20px;
    margin-top: 20px;
  }

  .footer__stat {
    text-align: center;
  }

  .footer__stat-number {
    font-size: 2rem;
    font-weight: 900;
    background: linear-gradient(135deg, #FF4D00, #FFB800);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .footer__stat-label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 4px;
  }

  /* Links */
  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__links li {
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__links a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .footer__links a:hover {
    color: #FF4D00;
  }

  .footer__date {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    margin-left: 8px;
  }

  /* Social */
  .footer__social {
    margin-top: 12px;
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: rgba(255, 77, 0, 0.1);
    border: 1px solid rgba(255, 77, 0, 0.3);
    border-radius: 8px;
    color: #FF4D00;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .footer__social-link:hover {
    background: rgba(255, 77, 0, 0.2);
    border-color: #FF4D00;
    transform: translateY(-2px);
  }

  .footer__social-link svg {
    color: #FF4D00;
  }

  /* Contact */
  .footer__contact-info {
    margin-top: 8px;
  }

  .footer__contact-info a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .footer__contact-info a:hover {
    color: #FFB800;
  }

  /* Sponsors */
  .footer__sponsors {
    text-align: center;
    padding: 30px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 30px;
  }

  .footer__sponsors-label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 10px;
  }

  .footer__sponsors-list {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  /* Bottom Section */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    margin-top: 30px;
  }

  @media (max-width: 640px) {
    .footer__bottom {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }

  .footer__copyright p {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }

  /* Powered by PRAZIS - Sutil */
  .footer__powered {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  @media (max-width: 640px) {
    .footer__powered {
      flex-direction: column;
      gap: 4px;
    }
  }

  .footer__powered-text {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  .footer__powered-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: rgba(255, 77, 0, 0.05);
    border: 1px solid rgba(255, 77, 0, 0.2);
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .footer__powered-link:hover {
    background: rgba(255, 77, 0, 0.1);
    border-color: rgba(255, 77, 0, 0.4);
    transform: translateY(-1px);
  }

  .footer__powered-link svg {
    color: #FFB800;
    width: 14px;
    height: 14px;
  }

  .footer__powered-brand {
    font-size: 0.8rem;
    font-weight: 600;
    color: #FF4D00;
    letter-spacing: 0.03em;
  }

  .footer__powered-link:hover .footer__powered-brand {
    color: #FFB800;
  }

  /* Payment Icons (optional) */
  .footer__payment {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-top: 20px;
  }

  .footer__payment svg {
    width: 40px;
    height: auto;
    opacity: 0.6;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Footer DHMEXRACES"
    },
    {
      "type": "paragraph",
      "content": "El footer es automático y contiene toda la información de DHMEXRACES, enlaces, redes sociales y copyright."
    }
  ]
}
{% endschema %}
