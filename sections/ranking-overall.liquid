<div class="ranking-overall">
  <div class="ranking-overall__container">
    <h1 class="ranking-overall__title">{{ section.settings.title }}</h1>
    <p class="ranking-overall__subtitle">{{ section.settings.subtitle }}</p>

    <!-- Category Filter Buttons -->
    <div class="ranking-overall__filters" id="overallFilters"></div>

    <!-- Overall Ranking Table -->
    <div class="ranking-overall__table-wrapper">
      <div class="ranking-overall__table" id="overallTable">
        <div class="ranking-overall__table-header">
          <div class="ranking-overall__table-cell">Pos</div>
          <div class="ranking-overall__table-cell">Nombre</div>
          <div class="ranking-overall__table-cell">Categoría</div>
          <div class="ranking-overall__table-cell">Equipo</div>
          <div class="ranking-overall__table-cell">Puntos</div>
          <div class="ranking-overall__table-cell">Diferencia</div>
        </div>

        <div class="ranking-overall__table-body" id="overallTableBody">
          <!-- Rows will be generated by JavaScript -->
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .ranking-overall {
    min-height: 100vh;
    background: #000;
    padding: 120px 2rem 4rem;
  }

  .ranking-overall__container {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }

  .ranking-overall__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    text-align: center;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .ranking-overall__subtitle {
    text-align: center;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.125rem;
    margin-bottom: 3rem;
  }

  .ranking-overall__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .category-filter-btn {
    padding: 0.625rem 1.25rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--color-border-accent);
    border-radius: 8px;
    color: #FFFFFF;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    letter-spacing: 0.05em;
  }

  .category-filter-btn:hover {
    background: rgba(0, 102, 179, 0.2);
    border-color: var(--color-secondary);
    transform: translateY(-2px);
  }

  .category-filter-btn.active {
    background: var(--color-secondary);
    color: #fff;
    border-color: var(--color-secondary);
    font-weight: 700;
  }

  .ranking-overall__table-wrapper {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(228, 44, 44, 0.2);
    border-radius: 12px;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch; /* Smooth scrolling on iOS */
  }

  .ranking-overall__table {
    width: 100%;
    min-width: 800px; /* Ensures table doesn't get too cramped */
  }

  .ranking-overall__table-header {
    display: grid;
    grid-template-columns: 60px 1fr 150px 150px 100px 120px;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    background: rgba(228, 44, 44, 0.1);
    border-bottom: 2px solid var(--color-border-accent);
  }

  .ranking-overall__table-cell {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: center;
  }

  .ranking-overall__table-cell--sede {
    color: var(--color-secondary);
    font-size: 0.75rem;
  }

  .ranking-overall__table-body {
    /* Rows added dynamically */
  }

  .ranking-overall__row {
    display: grid;
    grid-template-columns: 60px 1fr 150px 150px 100px 120px;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
    align-items: center;
  }

  .ranking-overall__row:hover {
    background: rgba(228, 44, 44, 0.05);
  }

  /* Podium styles */
  .ranking-overall__row--position-1 {
    background: rgba(255, 215, 0, 0.08);
    border-left: 4px solid #FFD700;
  }

  .ranking-overall__row--position-2 {
    background: rgba(192, 192, 192, 0.08);
    border-left: 4px solid #C0C0C0;
  }

  .ranking-overall__row--position-3 {
    background: rgba(205, 127, 50, 0.08);
    border-left: 4px solid #CD7F32;
  }

  .ranking-overall__position {
    font-size: 1.5rem;
    font-weight: 900;
    color: #FFFFFF;
    text-align: center;
  }

  .ranking-overall__row--position-1 .ranking-overall__position {
    color: #FFD700;
  }

  .ranking-overall__row--position-2 .ranking-overall__position {
    color: #C0C0C0;
  }

  .ranking-overall__row--position-3 .ranking-overall__position {
    color: #CD7F32;
  }

  .ranking-overall__name {
    font-size: 1.125rem;
    font-weight: 700;
    color: #FFFFFF;
  }

  .ranking-overall__category {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .ranking-overall__team {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  .ranking-overall__points {
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--color-gold);
    text-align: center;
  }

  .ranking-overall__difference {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-align: center;
  }

  .ranking-overall__difference--leader {
    color: var(--color-success);
  }

  .ranking-overall__sede-points {
    font-size: 0.95rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.85);
    text-align: center;
  }

  .ranking-overall__sede-points--empty {
    font-size: 0.95rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
  }

  .ranking-overall__no-data {
    text-align: center;
    padding: 3rem 2rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 1.125rem;
  }

  @media (max-width: 768px) {
    .ranking-overall {
      padding: 100px 0 2rem;
    }

    .ranking-overall__container {
      padding: 0;
      max-width: 100%;
    }

    .ranking-overall__table-wrapper {
      border-radius: 0;
      margin: 0;
      border-left: none;
      border-right: none;
    }

    .ranking-overall__table {
      min-width: max-content; /* Ensures table is as wide as needed */
      width: max-content;
    }

    .ranking-overall__table-header,
    .ranking-overall__row {
      gap: 0.5rem;
      padding: 0.75rem 1rem;
      /* Grid template columns handled by JavaScript */
    }

    .ranking-overall__title {
      font-size: 2rem;
      padding: 0 1rem;
    }

    .ranking-overall__subtitle {
      font-size: 0.95rem;
      padding: 0 1rem;
      margin-bottom: 2rem;
    }

    .ranking-overall__filters {
      padding: 0 1rem;
      margin-bottom: 1.5rem;
    }

    .ranking-overall__position {
      font-size: 1rem;
    }

    .ranking-overall__name {
      font-size: 0.875rem;
    }

    .ranking-overall__category {
      font-size: 0.75rem;
    }

    .ranking-overall__team {
      font-size: 0.75rem;
    }

    .ranking-overall__points {
      font-size: 0.875rem;
    }

    .ranking-overall__sede-points {
      font-size: 0.85rem;
    }

    .ranking-overall__difference {
      font-size: 0.75rem;
    }

    .ranking-overall__table-cell {
      font-size: 0.75rem;
      white-space: nowrap;
      padding: 0.25rem;
    }

    .ranking-overall__table-cell--sede {
      font-size: 0.7rem;
    }

    /* Show scroll hint */
    .ranking-overall__table-wrapper::after {
      content: '← Desliza para ver más →';
      display: block;
      text-align: center;
      padding: 0.75rem;
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.5);
      background: rgba(0, 0, 0, 0.3);
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Fetch ranking page and extract race data
    fetchRankingData();
  });

  async function fetchRankingData() {
    try {
      // Fetch the ranking page
      const response = await fetch('/pages/ranking');
      const html = await response.text();

      // Parse HTML
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');

      // Get all race cards with completed status
      const raceCards = doc.querySelectorAll('.ranking-card');
      console.log('Found', raceCards.length, 'race cards');
      const racesBySede = [];

      raceCards.forEach((card, raceIndex) => {
        // Check if race is completed (has results table)
        const resultsTable = card.querySelector('.ranking-table');
        if (!resultsTable) return;

        // Get race name from card header
        const raceName = card.querySelector('.ranking-card__title')?.textContent.trim() || `Sede ${raceIndex + 1}`;

        const sedeResults = [];

        // Get all result rows
        const rows = card.querySelectorAll('.ranking-table__row[data-category]');

        rows.forEach(row => {
          const position = row.querySelector('.ranking-table__position span')?.textContent.trim();
          const name = row.querySelector('.ranking-table__rider-name')?.textContent.trim();
          const category = row.querySelector('.ranking-table__category-badge')?.textContent.trim();
          const team = row.querySelector('.ranking-table__team')?.textContent.trim() || 'Sin equipo';
          const pointsText = row.querySelector('.ranking-table__points')?.textContent.trim();
          const points = parseInt(pointsText) || 0;

          if (name && category && points) {
            sedeResults.push({
              name,
              category,
              team,
              points
            });
          }
        });

        if (sedeResults.length > 0) {
          racesBySede.push({
            raceName,
            results: sedeResults
          });
        }
      });

      console.log('Total races found:', racesBySede.length);
      console.log('Races:', racesBySede);

      // Calculate overall standings
      const overallStandings = calculateOverallStandings(racesBySede);

      console.log('Overall standings calculated:', overallStandings.length);

      // Render the overall table
      renderOverallTable(overallStandings, racesBySede);

    } catch (error) {
      console.error('Error fetching ranking data:', error);
      document.getElementById('overallTableBody').innerHTML =
        '<div class="ranking-overall__no-data">Error al cargar los datos. Por favor recarga la página.</div>';
    }
  }

  function calculateOverallStandings(racesBySede) {
    const riders = {};

    // Process each sede separately
    racesBySede.forEach((sede, sedeIndex) => {
      // Group results by rider within this sede
      const sedeRiders = {};

      sede.results.forEach(result => {
        const riderKey = `${result.name.toLowerCase()}-${result.category.toLowerCase()}`;

        // Keep only the BEST (highest points) result for this rider in this sede
        if (!sedeRiders[riderKey] || result.points > sedeRiders[riderKey].points) {
          sedeRiders[riderKey] = {
            name: result.name,
            category: result.category,
            team: result.team,
            points: result.points
          };
        }
      });

      // Now add the best result from this sede to the overall standings
      Object.keys(sedeRiders).forEach(riderKey => {
        const sedeResult = sedeRiders[riderKey];

        if (!riders[riderKey]) {
          riders[riderKey] = {
            name: sedeResult.name,
            category: sedeResult.category,
            team: sedeResult.team,
            totalPoints: 0,
            pointsBySede: {} // Object to store points per sede
          };
        }

        // Store points for this specific sede
        riders[riderKey].pointsBySede[sedeIndex] = sedeResult.points;

        // Add the BEST points from this sede
        riders[riderKey].totalPoints += sedeResult.points;

        // Keep the most recent team
        if (sedeResult.team && sedeResult.team !== 'Sin equipo') {
          riders[riderKey].team = sedeResult.team;
        }
      });
    });

    // Convert to array and sort by points (descending), then by name
    const standings = Object.values(riders).sort((a, b) => {
      if (b.totalPoints !== a.totalPoints) {
        return b.totalPoints - a.totalPoints;
      }
      return a.name.localeCompare(b.name);
    });

    return standings;
  }

  function renderOverallTable(standings, racesBySede) {
    const tableBody = document.getElementById('overallTableBody');
    const filtersContainer = document.getElementById('overallFilters');

    if (!standings || standings.length === 0) {
      tableBody.innerHTML = '<div class="ranking-overall__no-data">No hay datos de ranking disponibles aún.</div>';
      return;
    }

    // Update table header with dynamic sede columns
    updateTableHeader(racesBySede);

    // Get unique categories
    const categories = [...new Set(standings.map(r => r.category))].sort();

    // Create category filter buttons (only if more than 1 category)
    if (categories.length > 1) {
      categories.forEach((category, index) => {
        const button = document.createElement('button');
        button.className = index === 0 ? 'category-filter-btn active' : 'category-filter-btn';
        button.textContent = category;
        button.setAttribute('data-category', category);
        button.addEventListener('click', function() {
          document.querySelectorAll('.category-filter-btn').forEach(btn => btn.classList.remove('active'));
          this.classList.add('active');
          filterByCategory(category, standings, racesBySede);
        });
        filtersContainer.appendChild(button);
      });
    }

    // Render initial table (first category or all if only one)
    if (categories.length > 1) {
      filterByCategory(categories[0], standings, racesBySede);
    } else {
      renderRows(standings, racesBySede);
    }
  }

  function updateTableHeader(racesBySede) {
    const header = document.querySelector('.ranking-overall__table-header');

    console.log('Updating header with', racesBySede.length, 'sedes');
    console.log('Window width:', window.innerWidth);

    // Check if mobile
    const isMobile = window.innerWidth <= 768;
    console.log('Is mobile:', isMobile);

    // Build dynamic grid template with fixed widths for better mobile scrolling
    let gridColumns;

    if (isMobile) {
      // Mobile: use fixed pixel widths to force horizontal scroll
      gridColumns = '50px 140px 90px 90px'; // Pos, Name, Category, Team

      // Add column for each sede
      racesBySede.forEach(() => {
        gridColumns += ' 60px'; // Sede points column (narrower on mobile)
      });

      gridColumns += ' 70px 70px'; // Total, Difference
    } else {
      // Desktop: use flexible widths
      gridColumns = '60px minmax(180px, 2fr) 120px 120px'; // Pos, Name, Category, Team

      // Add column for each sede
      racesBySede.forEach(() => {
        gridColumns += ' 80px'; // Sede points column
      });

      gridColumns += ' 100px 100px'; // Total, Difference
    }

    console.log('Grid columns:', gridColumns);

    // Update header grid
    header.style.gridTemplateColumns = gridColumns;

    // Force the table wrapper to allow scroll
    const wrapper = document.querySelector('.ranking-overall__table-wrapper');
    if (wrapper) {
      wrapper.style.overflowX = 'auto';
    }

    // Build header HTML
    let headerHTML = `
      <div class="ranking-overall__table-cell">Pos</div>
      <div class="ranking-overall__table-cell">Nombre</div>
      <div class="ranking-overall__table-cell">Categoría</div>
      <div class="ranking-overall__table-cell">Equipo</div>
    `;

    // Add sede headers
    racesBySede.forEach((sede, index) => {
      // Shorten the race name for header
      const shortName = sede.raceName.replace('INSCRIPCION SEDE', 'S').replace('GUANAJUATO 2026', '').trim() || `S${index + 1}`;
      headerHTML += `<div class="ranking-overall__table-cell ranking-overall__table-cell--sede">${shortName}</div>`;
    });

    headerHTML += `
      <div class="ranking-overall__table-cell">Total</div>
      <div class="ranking-overall__table-cell">Dif</div>
    `;

    header.innerHTML = headerHTML;
  }

  function filterByCategory(selectedCategory, allStandings, racesBySede) {
    const filtered = allStandings.filter(r => r.category === selectedCategory);
    renderRows(filtered, racesBySede);
  }

  function renderRows(standings, racesBySede) {
    const tableBody = document.getElementById('overallTableBody');
    tableBody.innerHTML = '';

    if (standings.length === 0) {
      tableBody.innerHTML = '<div class="ranking-overall__no-data">No hay corredores en esta categoría.</div>';
      return;
    }

    const leaderPoints = standings[0].totalPoints;

    // Get grid template from header
    const header = document.querySelector('.ranking-overall__table-header');
    const gridColumns = header.style.gridTemplateColumns;

    standings.forEach((rider, index) => {
      const position = index + 1;
      const difference = position === 1 ? 'LÍD' : `-${leaderPoints - rider.totalPoints}`;

      const row = document.createElement('div');
      row.className = `ranking-overall__row ranking-overall__row--position-${position}`;
      row.style.gridTemplateColumns = gridColumns;

      let rowHTML = `
        <div class="ranking-overall__position">${position}</div>
        <div class="ranking-overall__name">${rider.name}</div>
        <div class="ranking-overall__category">${rider.category}</div>
        <div class="ranking-overall__team">${rider.team}</div>
      `;

      // Add points for each sede
      racesBySede.forEach((sede, sedeIndex) => {
        const points = rider.pointsBySede[sedeIndex] || 0;
        const pointsClass = points > 0 ? 'ranking-overall__sede-points' : 'ranking-overall__sede-points--empty';
        rowHTML += `<div class="${pointsClass}">${points > 0 ? points : '-'}</div>`;
      });

      rowHTML += `
        <div class="ranking-overall__points">${rider.totalPoints}</div>
        <div class="ranking-overall__difference ${position === 1 ? 'ranking-overall__difference--leader' : ''}">${difference}</div>
      `;

      row.innerHTML = rowHTML;
      tableBody.appendChild(row);
    });
  }
</script>

{% schema %}
{
  "name": "Ranking Overall",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Ranking Overall 2026"
