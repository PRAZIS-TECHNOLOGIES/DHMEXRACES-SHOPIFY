    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Clasificación general acumulada de todas las fechas del campeonato"
    },
    {
      "type": "paragraph",
      "content": "Esta página obtiene automáticamente los datos de la página de Ranking. No requiere configuración adicional."
    }
  ]
}
{% endschema %}
